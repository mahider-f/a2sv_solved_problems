t = int(input())

for _ in range(t):
    n,k = map(int,input().split())
    cells = input()
    count = 0
    for i in range(k):
        if cells[i] == 'W':
            count+=1
    min_count = count

    for i in range(k,n):
        if cells[i] == 'W':
            count +=1
        if cells[i-k] == 'W':
            count -=1
        min_count = min(min_count, count)
    print(min_count)



        

    
