class Solution:
    def judgeSquareSum(self, c: int) -> bool:

        a = 0
        b = int(sqrt(c))

        while a <= b:
            if a**2 + b**2 == c:
                return True

            if a**2 + b**2 < c:
                a+=1

            if a**2 + b**2 > c:
                b-=1
        return False

        
