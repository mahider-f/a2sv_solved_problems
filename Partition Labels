class Solution:
    def partitionLabels(self, s: str) -> List[int]:
        d = {}
        start = 0
        max_ = 0
        ans = []
        prev = 0
        for i in range(len(s)):
            d[s[i]] = i

        for j in range(len(s)):
            max_= max(max_, d[s[j]])

            if j == max_:
                ans.append(max_ - prev)
                prev = max_
                start+=1
        ans[0] +=1
        return ans


        

        
